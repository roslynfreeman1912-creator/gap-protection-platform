# TEUFEL SHIELD - AI Vulnerability Scanner API Keys
# Copy this file to .env and fill in your actual values

# Claude API Keys (comma-separated for rotation)
CLAUDE_API_KEYS=your_api_key_1,your_api_key_2,your_api_key_3

# Claude API Configuration
CLAUDE_API_URL=https://api.anthropic.com/v1/messages
CLAUDE_MODEL=claude-sonnet-4-20250514

# Database Configuration (optional - required for WAF/Shield features)
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/gap_protection

# Server Configuration
PORT=5000
NODE_ENV=production

# Security Settings
SESSION_SECRET=generate_a_random_secret_key_here
CORS_ORIGIN=https://yourdomain.com

# Company Configuration (override config.py defaults)
COMPANY_NAME="Your Company Name"
COMPANY_EMAIL=security@yourcompany.com
COMPANY_PHONE="+1 XXX XXX XXXX"
COMPANY_WEBSITE=https://yourcompany.com
